---
import Card from './ui/Card.astro';
import SectionWrapper from './ui/SectionWrapper.astro';

const SDD_PHASES = [
  'Init',
  'Explore',
  'Propose',
  'Spec',
  'Design',
  'Tasks',
  'Apply',
  'Verify',
  'Archive',
] as const;

type SddPhase = (typeof SDD_PHASES)[number];

const sddPhases: readonly SddPhase[] = SDD_PHASES;
---

<SectionWrapper id="sdd" revealType="fade">
  <div class="mx-auto max-w-6xl space-y-10">
    <div class="space-y-3 text-center">
      <h2 class="font-heading text-section font-bold text-text">Plans when it should. Executes when it can.</h2>
      <p class="text-text-muted">Spec-Driven Development — 9 phases, zero ceremony.</p>
    </div>

    <p class="mx-auto max-w-4xl text-center text-text-muted">
      Small request? The agent just does it. No ceremony. Substantial feature? The agent will suggest using SDD to
      plan it properly.
    </p>

    <div class="sdd-pipeline-wrap">
      <ol
        class="sdd-pipeline"
        aria-label="SDD workflow phases"
        data-reveal-stagger
        style="--stagger-animation: slide-in-right; --stagger-step: 90ms;"
      >
      {
        sddPhases.map((phase, index) => (
          <li class="sdd-pipeline__item" data-active={index < 4 ? true : undefined} data-reveal-item style={`--item-index: ${index};`}>
            <span class="sdd-pipeline__node" aria-hidden="true"></span>
            <span class="sdd-pipeline__label">
              <span class="text-text-dim">{index + 1}.</span> {phase}
            </span>
          </li>
        ))
      }
      </ol>
    </div>

    <Card class="mx-auto max-w-4xl space-y-3">
      <h3 class="text-xl font-bold text-text">Multi-Mode SDD</h3>
      <p class="text-text-muted">
        Assign different AI models to different phases. Use a powerful model for design, a fast one for
        implementation. Save tokens without sacrificing quality.
      </p>
      <p class="text-sm text-text-dim">Available in OpenCode with connected providers.</p>
    </Card>
  </div>
</SectionWrapper>

<style>
  .sdd-pipeline-wrap {
    overflow-x: auto;
    padding-block: 0.5rem;
  }

  .sdd-pipeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    min-width: fit-content;
  }

  .sdd-pipeline__item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-right: 1rem;
  }

  .sdd-pipeline__node {
    position: relative;
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 9999px;
    border: 1px solid rgb(234 24 137 / 0.35);
    background-color: rgb(10 10 10 / 1);
    box-shadow: 0 0 0 3px rgb(234 24 137 / 0.08);
    flex-shrink: 0;
  }

  .sdd-pipeline__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(136 136 136 / 1);
    white-space: nowrap;
  }

  .sdd-pipeline__item::after {
    content: '';
    position: absolute;
    left: 0.42rem;
    top: calc(100% + 0.15rem);
    width: 1px;
    height: 1rem;
    background: linear-gradient(180deg, rgb(234 24 137 / 0.5) 0%, rgb(184 18 107 / 0.18) 100%);
  }

  .sdd-pipeline__item::before {
    content: '';
    position: absolute;
    left: 0.42rem;
    top: calc(100% + 0.15rem);
    width: 1px;
    height: 1rem;
    background-image: linear-gradient(180deg, transparent 0%, rgb(234 24 137 / 0.9) 48%, transparent 100%);
    background-size: 100% 220%;
    opacity: 0;
  }

  .sdd-pipeline__item:last-child::after,
  .sdd-pipeline__item:last-child::before {
    display: none;
  }

  .sdd-pipeline__item[data-active] .sdd-pipeline__node {
    border-color: rgb(234 24 137 / 0.58);
    animation: border-glow 2.4s ease-in-out infinite;
  }

  @media (min-width: 768px) {
    .sdd-pipeline {
      flex-direction: row;
      gap: 2rem;
      padding-inline: 0.5rem;
    }

    .sdd-pipeline__item {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      padding-right: 0;
      min-width: 5.75rem;
    }

    .sdd-pipeline__item::after,
    .sdd-pipeline__item::before {
      left: calc(100% + 0.35rem);
      top: 0.42rem;
      width: 1.45rem;
      height: 1px;
    }

    .sdd-pipeline__item::after {
      background: linear-gradient(90deg, rgb(234 24 137 / 0.5) 0%, rgb(184 18 107 / 0.18) 100%);
    }

    .sdd-pipeline__item::before {
      background-image: linear-gradient(90deg, transparent 0%, rgb(234 24 137 / 0.9) 48%, transparent 100%);
      background-size: 240% 100%;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .sdd-pipeline__item::before {
      animation: shimmer 2.8s linear infinite;
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sdd-pipeline__item::before,
    .sdd-pipeline__item[data-active] .sdd-pipeline__node {
      animation: none !important;
    }
  }
</style>
