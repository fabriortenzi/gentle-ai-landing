---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props as Props;
---

<img
  src="/bigote.png"
  alt=""
  aria-hidden="true"
  class={`mustache-bullet ${className}`}
  loading="lazy"
  decoding="async"
/>

<style>
  .mustache-bullet {
    width: auto;
    height: 0.6rem;
    flex-shrink: 0;
    opacity: 0.85;
    object-fit: contain;
  }
</style>
