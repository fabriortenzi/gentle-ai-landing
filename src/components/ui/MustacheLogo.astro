---
const LOGO_SIZES = {
  sm: 24,
  md: 48,
  lg: 80,
} as const;

type LogoSize = keyof typeof LOGO_SIZES;

interface Props {
  size?: LogoSize;
  glow?: boolean;
  class?: string;
}

const { size = 'md', glow = false, class: className = '' } = Astro.props as Props;
const pixelSize = LOGO_SIZES[size];
const glowClass = glow || size === 'lg' ? 'mustache-logo--glow' : '';
---

<span class={`mustache-logo inline-flex ${glowClass} ${className}`}>
  <span class="mustache-logo__glow" aria-hidden="true"></span>

  <img
    src="/bigote.png"
    alt="Gentleman Programming"
    class="mustache-logo__img"
    style={`height: ${pixelSize}px;`}
    loading="lazy"
    decoding="async"
  />
</span>

<style>
  .mustache-logo {
    position: relative;
    isolation: isolate;
  }

  .mustache-logo__img {
    position: relative;
    z-index: 1;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .mustache-logo__glow {
    position: absolute;
    inset: -24% -18%;
    border-radius: 9999px;
    background: radial-gradient(circle at center, rgb(234 24 137 / 0.26) 0%, rgb(234 24 137 / 0) 72%);
    filter: blur(8px);
    opacity: 0;
    pointer-events: none;
  }

  .mustache-logo--glow {
    filter: drop-shadow(0 0 20px rgb(234 24 137 / 0.3));
  }

  .mustache-logo--glow .mustache-logo__glow {
    opacity: 1;
    animation: pulse-glow 3.8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mustache-logo__img {
      animation: mustache-float 6s ease-in-out infinite;
    }
  }

  @keyframes mustache-float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mustache-logo__glow,
    .mustache-logo__img {
      animation: none !important;
    }
  }
</style>
