---
const LOGO_SIZES = {
  sm: 24,
  md: 48,
  lg: 80,
} as const;

type LogoSize = keyof typeof LOGO_SIZES;

interface Props {
  size?: LogoSize;
  glow?: boolean;
  class?: string;
}

const { size = 'md', glow = false, class: className = '' } = Astro.props as Props;
const pixelSize = LOGO_SIZES[size];
const glowClass = glow || size === 'lg' ? 'mustache-logo--glow' : '';
---

<span class={`mustache-logo inline-flex ${glowClass} ${className}`}>
  <span class="mustache-logo__glow" aria-hidden="true"></span>

  <svg
    viewBox="0 0 240 96"
    role="img"
    aria-label="Gentleman Programming"
    class="mustache-logo__svg w-auto"
    width={pixelSize}
    height={pixelSize}
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      class="mustache-logo__path"
      d="M120 56C106 56 94 60 81 68C66 78 48 80 34 70C22 61 20 44 29 33C38 22 55 24 66 34C74 41 76 50 71 59C66 69 56 74 46 74C56 86 74 91 93 86C108 82 117 70 120 56Z"
      fill="currentColor"
    />
    <path
      class="mustache-logo__path"
      d="M120 56C134 56 146 60 159 68C174 78 192 80 206 70C218 61 220 44 211 33C202 22 185 24 174 34C166 41 164 50 169 59C174 69 184 74 194 74C184 86 166 91 147 86C132 82 123 70 120 56Z"
      fill="currentColor"
    />
    <path
      class="mustache-logo__path"
      d="M76 52C90 43 104 38 120 38C136 38 150 43 164 52C160 67 146 76 120 76C94 76 80 67 76 52Z"
      fill="currentColor"
      fill-opacity="0.9"
    />
  </svg>
</span>

<style>
  .mustache-logo {
    position: relative;
    isolation: isolate;
  }

  .mustache-logo__svg {
    position: relative;
    z-index: 1;
  }

  .mustache-logo__glow {
    position: absolute;
    inset: -24% -18%;
    border-radius: 9999px;
    background: radial-gradient(circle at center, rgb(234 24 137 / 0.26) 0%, rgb(234 24 137 / 0) 72%);
    filter: blur(8px);
    opacity: 0;
    pointer-events: none;
  }

  .mustache-logo--glow {
    filter: drop-shadow(0 0 20px rgb(234 24 137 / 0.3));
  }

  .mustache-logo--glow .mustache-logo__glow {
    opacity: 1;
    animation: pulse-glow 3.8s ease-in-out infinite;
  }

  .mustache-logo__path {
    transform-box: fill-box;
    transform-origin: center;
    animation: mustache-float 6s ease-in-out infinite;
  }

  .mustache-logo__path:nth-child(2) {
    animation-delay: 0.35s;
  }

  .mustache-logo__path:nth-child(3) {
    animation-delay: 0.7s;
  }

  @keyframes mustache-float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mustache-logo__glow,
    .mustache-logo__path {
      animation: none !important;
    }
  }
</style>
