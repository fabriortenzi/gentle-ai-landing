---
interface Props {
  title?: string;
  class?: string;
  [key: string]: unknown;
}

const { title = 'terminal', class: className = '', ...rest } = Astro.props as Props;
---

<div {...rest} class={`terminal-shell rounded-lg border border-border overflow-hidden ${className}`}>
  <div class="bg-surface-2 px-4 py-2.5 flex items-center gap-2">
    <div class="flex gap-1.5">
      <span class="h-3 w-3 rounded-full bg-terminal-red"></span>
      <span class="h-3 w-3 rounded-full bg-terminal-yellow"></span>
      <span class="h-3 w-3 rounded-full bg-terminal-green"></span>
    </div>
    <span class="text-text-dim text-sm font-mono ml-2">{title}</span>
  </div>
  <div class="terminal-content bg-dark p-4 font-mono text-sm leading-relaxed">
    <slot />
  </div>
</div>

<style>
  .terminal-content {
    position: relative;
    overflow: hidden;
    box-shadow: inset 0 0 30px rgb(234 24 137 / 0.05);
  }

  .terminal-content::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent 0%, rgb(234 24 137 / 0.15) 50%, transparent 100%);
  }

  .terminal-content::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgb(255 255 255 / 0.03) 0px,
      rgb(255 255 255 / 0.03) 1px,
      transparent 1px,
      transparent 3px
    );
    mix-blend-mode: screen;
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-content::after {
      background: none;
    }
  }
</style>
