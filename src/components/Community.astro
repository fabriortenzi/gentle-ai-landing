---
import Card from './ui/Card.astro';
import SectionWrapper from './ui/SectionWrapper.astro';

const SOCIAL_LINKS = [
  {
    icon: 'youtube' as const,
    label: 'YouTube',
    href: 'https://www.youtube.com/@GentlemanProgramming',
  },
  {
    icon: 'github' as const,
    label: 'GitHub',
    href: 'https://github.com/Gentleman-Programming',
  },
  {
    icon: 'twitch' as const,
    label: 'Twitch',
    href: 'https://www.twitch.tv/gentlemanprogramming',
  },
  {
    icon: 'discord' as const,
    label: 'Discord',
    href: 'https://discord.gg/53QtSvaMWM',
  },
] as const;

type SocialLink = (typeof SOCIAL_LINKS)[number];

const socialLinks: readonly SocialLink[] = SOCIAL_LINKS;
const year = new Date().getFullYear();
---

<SectionWrapper id="community" class="pb-12" revealType="fade">
  <div class="mx-auto max-w-5xl space-y-12">
    <div class="space-y-4 text-center">
      <h2 class="font-heading text-section font-bold text-text">Built by the community. Led by a Gentleman.</h2>
    </div>

    <Card
      class="community-tribute-card mx-auto max-w-4xl space-y-6 rounded-2xl p-8 text-center"
      style="--card-border-color: rgb(234 24 137 / 0.2); --card-hover-shadow: 0 8px 30px rgb(234 24 137 / 0.18), 0 0 52px rgb(234 24 137 / 0.14);"
    >
      <div class="flex justify-center">
        <img
          src="/logo_gentleman.png"
          alt="Gentleman Programming"
          class="h-16 w-auto"
          loading="lazy"
          decoding="async"
        />
      </div>

      <p class="text-text-muted">
        Alan Buscaglia, aka Gentleman Programming, created gentle-ai and Engram to prove that AI agents can be more
        than chatbots. A consultant, educator, and GDE who believes in foundations over frameworks, concepts over
        code, and building people up — even if it means being brutally honest.
      </p>

      <p class="text-fucsia italic">“You are Tony Stark. AI is Jarvis. You direct, it executes.”</p>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-text-muted transition-colors hover:text-fucsia focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-fucsia focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
            >
              {
                link.icon === 'youtube' && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-[1.125rem] w-[1.125rem] fill-current">
                    <path d="M23.5 7.3a3.1 3.1 0 0 0-2.2-2.2C19.4 4.6 12 4.6 12 4.6s-7.4 0-9.3.5A3.1 3.1 0 0 0 .5 7.3C0 9.2 0 12 0 12s0 2.8.5 4.7a3.1 3.1 0 0 0 2.2 2.2c1.9.5 9.3.5 9.3.5s7.4 0 9.3-.5a3.1 3.1 0 0 0 2.2-2.2c.5-1.9.5-4.7.5-4.7s0-2.8-.5-4.7ZM9.6 15.8V8.2L16.2 12l-6.6 3.8Z" />
                  </svg>
                )
              }
              {
                link.icon === 'github' && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-[1.125rem] w-[1.125rem] fill-current">
                    <path d="M12 0a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1 2 .8 2.4 1.7.9.4 1.7.6 2.6.6l.6-2.4c-2.8-.3-5.8-1.4-5.8-6.3 0-1.4.5-2.5 1.2-3.4-.1-.3-.5-1.6.1-3.4 0 0 1-.3 3.4 1.3a11.8 11.8 0 0 1 6.2 0c2.3-1.6 3.3-1.3 3.3-1.3.7 1.8.3 3.1.2 3.4.8.9 1.2 2 1.2 3.4 0 4.9-3 6-5.9 6.3l.9.8v3c0 .3.2.7.8.6A12 12 0 0 0 12 0Z" />
                  </svg>
                )
              }
              {
                link.icon === 'twitch' && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-[1.125rem] w-[1.125rem] fill-current">
                    <path d="M4.1 1 1 4.1V20h5.3v3H9l3-3h3.6l6.4-6.4V1H4.1Zm16.1 11.4-3.6 3.6h-4l-3 3v-3H4.8V2.8h15.4v9.6ZM15.7 6H18v5.8h-2.3V6Zm-5.8 0h2.3v5.8H9.9V6Z" />
                  </svg>
                )
              }
              {
                link.icon === 'discord' && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-[1.125rem] w-[1.125rem] fill-current">
                    <path d="M20.3 4.7A16.4 16.4 0 0 0 16.2 3l-.2.4c-.1.3-.3.6-.4 1A15.3 15.3 0 0 0 8.5 4a11 11 0 0 0-.7-1L7.6 3a16.7 16.7 0 0 0-4.1 1.7C1 8.2.4 11.6.7 15l.1.5c1.8 1.4 3.6 2.2 5.4 2.7l.4-.6.7-1.1c-1-.4-1.8-.8-2.7-1.4l.6-.4c1.8.9 3.7 1.5 6.8 1.5s5-.6 6.8-1.5l.6.4c-.8.6-1.7 1-2.7 1.4l.7 1.1.4.6c1.9-.5 3.7-1.3 5.5-2.7l.1-.5c.4-3.9-.6-7.2-3.1-10.3ZM8.9 13.1c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6c.8 0 1.4.7 1.4 1.6s-.6 1.6-1.4 1.6Zm6.2 0c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6c.8 0 1.4.7 1.4 1.6s-.6 1.6-1.4 1.6Z" />
                  </svg>
                )
              }
              {link.label}
            </a>
          ))
        }
      </div>
    </Card>


  </div>
</SectionWrapper>

<footer class="border-border border-t bg-surface px-6 py-8">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 text-center text-sm text-text-muted md:flex-row">
    <p>Made with 🤍 by the Gentleman Programming community</p>
    <div class="flex items-center gap-3">
      <span>MIT License</span>
      <span aria-hidden="true">•</span>
      <span>{year}</span>
    </div>
  </div>
</footer>

<style>
  .community-tribute-card {
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgb(234 24 137 / 0.08), 0 20px 40px rgb(234 24 137 / 0.08);
  }

  .community-tribute-card::before {
    content: '';
    position: absolute;
    inset: -35% -10% auto;
    height: 75%;
    pointer-events: none;
    background: radial-gradient(circle at 50% 0%, rgb(234 24 137 / 0.2) 0%, rgb(234 24 137 / 0) 72%);
    opacity: 0.9;
  }
</style>
