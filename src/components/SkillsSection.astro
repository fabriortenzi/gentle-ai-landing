---
import Button from './ui/Button.astro';
import Card from './ui/Card.astro';
import SectionWrapper from './ui/SectionWrapper.astro';

const SDD_SKILLS = ['Init', 'Explore', 'Propose', 'Spec', 'Design', 'Tasks', 'Apply', 'Verify', 'Archive'] as const;

const FOUNDATION_SKILLS = ['Go Testing', 'Skill Creator', 'Branch & PR', 'Issue Creation'] as const;

const SPECIAL_SKILLS = ['Judgment Day'] as const;

const HOW_IT_WORKS = [
  {
    title: 'They discover skills on their own.',
    detail: 'Sub-agents search the skill registry',
  },
  {
    title: 'They adapt to your project.',
    detail: 'React project loads React skills, Go project loads Go skills',
  },
  {
    title: 'They persist their work.',
    detail: 'Artifacts saved to engram for the next agent',
  },
] as const;

type SddSkill = (typeof SDD_SKILLS)[number];
type FoundationSkill = (typeof FOUNDATION_SKILLS)[number];
type SpecialSkill = (typeof SPECIAL_SKILLS)[number];
type SkillsFeature = (typeof HOW_IT_WORKS)[number];

const sddSkills: readonly SddSkill[] = SDD_SKILLS;
const foundationSkills: readonly FoundationSkill[] = FOUNDATION_SKILLS;
const specialSkills: readonly SpecialSkill[] = SPECIAL_SKILLS;
const skillsFeatures: readonly SkillsFeature[] = HOW_IT_WORKS;
---

<SectionWrapper id="skills" revealType="fade-up">
  <div class="mx-auto max-w-6xl space-y-10">
    <div class="space-y-3 text-center">
      <h2 class="font-heading text-section font-bold text-text">Knows your stack. Automatically.</h2>
      <p class="text-text-muted">14 built-in skills + community library. Auto-detected, zero config.</p>
    </div>

    <div class="space-y-8">
      <div class="space-y-4">
        <h3 class="text-lg font-bold text-text">Built-in Skills</h3>

        <div
          class="flex flex-wrap gap-2"
          data-reveal-stagger
          style="--stagger-animation: fade-in-up; --stagger-step: 70ms;"
        >
          {
            sddSkills.map((skill, index) => (
              <span
                class="skills-pill rounded-full border border-fucsia/20 bg-surface-2 px-3 py-1 font-mono text-sm text-fucsia"
                data-reveal-item
                style={`--item-index: ${index}; --pill-float-delay: ${index * 0.24}s;`}
              >
                {skill}
              </span>
            ))
          }

          {
            foundationSkills.map((skill, index) => (
              <span
                class="skills-pill rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-sm text-text-muted"
                data-reveal-item
                style={`--item-index: ${index + sddSkills.length}; --pill-float-delay: ${(index + sddSkills.length) * 0.24}s;`}
              >
                {skill}
              </span>
            ))
          }

          {
            specialSkills.map((skill, index) => (
              <span
                class="skills-pill rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-sm text-text-muted"
                data-reveal-item
                style={`--item-index: ${index + sddSkills.length + foundationSkills.length}; --pill-float-delay: ${(index + sddSkills.length + foundationSkills.length) * 0.24}s;`}
              >
                {skill} <span class="text-text-dim">(parallel adversarial review)</span>
              </span>
            ))
          }
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="text-lg font-bold text-text">How it works</h3>
        <div class="grid gap-4 md:grid-cols-3">
          {
            skillsFeatures.map((item) => (
              <Card class="p-4">
                <p class="font-semibold text-text">{item.title}</p>
                <p class="mt-2 text-sm text-text-muted">{item.detail}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>

    <Card class="flex flex-col items-start justify-between gap-4 p-6 md:flex-row md:items-center">
      <p class="text-text-muted">Want more? React 19, Angular, TypeScript, Tailwind, Zod, Playwright...</p>
      <Button
        variant="ghost"
        href="https://github.com/Gentleman-Programming/Gentleman-Skills"
      >
        Browse Community Skills →
      </Button>
    </Card>
  </div>
</SectionWrapper>

<style>
  [data-reveal-stagger] {
    --stagger-step: 85ms;
  }

  [data-reveal-stagger].is-revealed .skills-pill {
    animation:
      var(--stagger-animation, fade-in-up) 0.62s ease-out both,
      float 8s ease-in-out infinite;
    animation-delay:
      calc(var(--stagger-start, 0ms) + (var(--item-index, 0) * var(--stagger-step, 130ms))),
      calc(0.72s + var(--stagger-start, 0ms) + (var(--item-index, 0) * var(--stagger-step, 130ms)) + var(--pill-float-delay, 0s));
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal-stagger].is-revealed .skills-pill {
      animation: none !important;
    }
  }
</style>
